{
  "job_name": "aletheia-slm-distill-v1",
  "base_model": "qwen2.5-1.5b-base",
  "method": "on_policy_distillation",
  "teacher": {
    "model_id": "llama-3.1-70b-instruct",
    "temperature": 0.7,
    "top_p": 0.9
  },
  "training_params": {
    "peft_type": "lora",
    "lora_rank": 128,
    "lora_alpha": 256,
    "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
    "learning_rate": 2e-4,
    "batch_size": 32,
    "gradient_accumulation_steps": 4,
    "num_epochs": 3,
    "lr_scheduler": "wsd",
    "wsd_stable_ratio": 0.8,
    "warmup_steps": 500
  },
  "distillation_params": {
    "distill_loss_weight": 0.7,
    "kl_divergence_weight": 0.3,
    "on_policy_sampling": true,
    "thinking_steps": true
  },
  "dataset": {
    "hf_path": "Open-Orca/SlimOrca-Dedup",
    "streaming": true,
    "context_length": 4096
  },
  "compute": {
    "precision": "bf16",
    "use_paged_optimizer": true
  }
}
